# ── LLM (Groq) ───────────────────────────────────────
LLM_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b

# ── Embeddings (OpenAI) ─────────────────────────────
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Gemini (deep paper analysis) ──────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-pro-preview

# ── Obsidian Vault ───────────────────────────────────
# Use forward slashes or escaped backslashes
OBSIDIAN_VAULT_PATH=ruta_a_tu_vault

# ── PostgreSQL + pgvector ────────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=agent_vectors
POSTGRES_PORT=5432
# Dentro de Docker Compose usa el hostname interno `db`; fuera de Docker cambia `db` por `localhost`
DATABASE_URL=postgresql://agent:cambia-esta-clave@db:5432/agent_vectors

# ── Crawl4AI ─────────────────────────────────────────
# (browser profiles are internal to each worker container)

# ── Scheduler ────────────────────────────────────────
# Hours of day to run FB scraping (comma-separated, 24h format)
SCRAPE_HOURS=8,20
# Hours of day to run YT scraping (comma-separated, 24h format)
YT_SCRAPE_HOURS=9
# Hour of day (0-23) to run Arxiv collection (once per day)
ARXIV_HOUR=7

# ── FB Marketplace ───────────────────────────────────
FB_SEARCH_QUERIES=laptop,gadgets,libros,equipos electronicos
FB_LOCATIONS=tacna:111957248821463,moquegua:108444959180261

# ── Arxiv ────────────────────────────────────────────
ARXIV_MAX_RESULTS_PER_QUERY=20

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=INFO
