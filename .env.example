# ── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5-mini

# ── Obsidian Vault ───────────────────────────────────
# Use forward slashes or escaped backslashes
OBSIDIAN_VAULT_PATH=ruta_a_tu_vault

# ── PostgreSQL + pgvector ────────────────────────────
DATABASE_URL=postgresql://agent:agent_secret@localhost:5432/agent_vectors
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Crawl4AI Browser Profiles ───────────────────────
BROWSER_PROFILES_DIR=./profiles
FB_PROFILE_NAME=fb-profile
GOOGLE_PROFILE_NAME=google-profile

# ── Scheduler ────────────────────────────────────────
# Hours of day to run FB+YT scraping (comma-separated, 24h format)
SCRAPE_HOURS=8,20
# Hour of day (0-23) to run Arxiv collection (once per day)
ARXIV_HOUR=7

# ── FB Marketplace ───────────────────────────────────
FB_SEARCH_QUERIES=laptop,gadgets,libros,equipos electronicos
FB_LOCATIONS=tacna,moquegua

# ── Arxiv ────────────────────────────────────────────
ARXIV_MAX_RESULTS_PER_QUERY=20

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=INFO
